{
  "scheduler": {"enabled": true, "weekdays": [0, 1, 2, 3, 4], "once_per_day": true, "dry_run": false},
  "files": {
    "pipeline_config": "config/v7_direct_pipeline_config.json",
    "scheduler_state": "state/v7_scheduler_state.json",
    "lock": "state/v7_scheduler.lock",
    "log_dir": "logs/scheduler"
  },
  "operations": {
    "enabled": true,
    "pipeline_summary": "reports/v7_direct_pipeline_summary.json",
    "report_json": "reports/v7_operations_report.json",
    "report_text": "reports/v7_operations_report.txt",
    "notification": {
      "enabled": false, "notify_on_success": false, "notify_on_failure": true,
      "webhook_env": "PHOENIX_V7_DISCORD_WEBHOOK_URL", "timeout_seconds": 15
    }
  },
  "performance": {
    "enabled": true,
    "history_jsonl": "reports/v7_run_history.jsonl",
    "summary_json": "reports/v7_performance_summary.json",
    "summary_text": "reports/v7_performance_summary.txt",
    "retention_runs": 365,
    "window_runs": 30
  },
  "diagnostics": {
    "enabled": true,
    "position_log": "reports/v7_direct_position_log.csv",
    "report_json": "reports/v7_decision_diagnostics.json",
    "report_text": "reports/v7_decision_diagnostics.txt"
  },
  "portfolio_guard": {
    "enabled": true,
    "advisory_only": true,
    "broker_state": "state/v7_paper_broker.json",
    "report_json": "reports/v7_portfolio_guard.json",
    "report_text": "reports/v7_portfolio_guard.txt",
    "default_stop_loss_pct": 0.05,
    "default_take_profit_pct": 0.10
  },
  "market_data_guard": {
    "enabled": true,
    "signals_file": "reports/trade_signals.csv",
    "broker_state": "state/v7_paper_broker.json",
    "guard_state": "state/v7_market_data_guard.json",
    "report_json": "reports/v7_market_data_guard.json",
    "report_text": "reports/v7_market_data_guard.txt",
    "max_age_hours": 96,
    "unchanged_warning_days": 2
  },
  "readiness_gate": {
    "enabled": true,
    "minimum_paper_days": 20,
    "minimum_success_rate": 0.95,
    "minimum_filled_orders": 3,
    "performance_report": "reports/v7_performance_summary.json",
    "operations_report": "reports/v7_operations_report.json",
    "market_data_report": "reports/v7_market_data_guard.json",
    "portfolio_report": "reports/v7_portfolio_guard.json",
    "lifecycle_report": "reports/v7_order_lifecycle.json",
    "report_json": "reports/v7_readiness_gate.json",
    "report_text": "reports/v7_readiness_gate.txt"
  },
  "order_lifecycle": {
    "enabled": true,
    "broker_state": "state/v7_paper_broker.json",
    "snapshot_state": "state/v7_order_lifecycle_snapshot.json",
    "event_journal": "state/v7_order_lifecycle_events.jsonl",
    "report_json": "reports/v7_order_lifecycle.json",
    "report_text": "reports/v7_order_lifecycle.txt",
    "retention_events": 2000
  }
}
